<!DOCTYPE html>
<html>

<head>

<title>CryptoScope AI - Login</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


<link rel="stylesheet" href="/css/style.css">

</head>


<body>



<div class="container mt-5">


<div class="glass-card">


<h2 id="title">
Login
</h2>




<form id="loginForm">


<input 
id="loginEmail"
class="form-control mb-3"
placeholder="Email"
>



<input 
id="loginPassword"
type="password"
class="form-control mb-3"
placeholder="Password"
>



<button class="btn btn-crypto">

Login

</button>


</form>





<form id="registerForm" style="display:none;">


<input 
id="registerName"
class="form-control mb-3"
placeholder="Name"
>



<input 
id="registerEmail"
class="form-control mb-3"
placeholder="Email"
>



<input 
id="registerPassword"
type="password"
class="form-control mb-3"
placeholder="Password"
>



<button class="btn btn-crypto">

Register

</button>



</form>






<p class="mt-3">


<span id="switchText">

Don't have account?

</span>


<a href="#" id="switchBtn">

Register

</a>



</p>



</div>


</div>





<script src="/js/auth.js"></script>


</body>

</html>